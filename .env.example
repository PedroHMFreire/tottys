# Supabase — obrigatório
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# Supabase server-side (Edge Functions, scripts de migração — NÃO usar no frontend)
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...   # NUNCA expor no cliente

# Email — Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
VITE_EMAIL_FROM=noreply@seudominio.com.br

# Fiscal (opcional)
VITE_FISCAL_PROVIDER=focusnfe
VITE_FISCAL_API_KEY=
VITE_FISCAL_ENV=homologacao

# Stripe — pagamentos e assinaturas (Edge Functions, não expor no frontend)
STRIPE_SECRET_KEY=sk_live_...         # ou sk_test_... em desenvolvimento
STRIPE_WEBHOOK_SECRET=whsec_...       # secret do webhook no Stripe Dashboard
STRIPE_PRICE_LOJA=price_...           # Price ID do plano Loja (R$ 129/mês)
STRIPE_PRICE_GESTAO=price_...         # Price ID do plano Gestão (R$ 249/mês)
STRIPE_PRICE_REDE=price_...           # Price ID do plano Rede (R$ 399/mês)
APP_URL=https://app.tottys.com.br     # URL base para redirect pós-checkout

# Sentry — monitoramento de erros (https://sentry.io)
VITE_SENTRY_DSN=
VITE_APP_VERSION=0.1.0
